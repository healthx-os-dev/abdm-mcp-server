# ── ABDM Gateway Credentials (server-side only, never exposed to clients) ──
ABDM_CLIENT_ID=your-abdm-client-id
ABDM_CLIENT_SECRET=your-abdm-client-secret
ABDM_BASE_URL=https://dev.abdm.gov.in/gateway
ABDM_CM_ID=sbx

# ── Security ───────────────────────────────────────────────────────────────
# JWT secret for internal Bearer token auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRY=3600

# Admin API key — used to generate/revoke client hx_ keys via /admin/keys
# Generate a strong key: openssl rand -hex 32
ADMIN_API_KEY=your-secret-admin-key-here

# ── Webhooks ───────────────────────────────────────────────────────────────
# Public URL where ABDM will POST async callbacks
# Use ngrok for local dev: ngrok http 3000
WEBHOOK_BASE_URL=https://your-ngrok-or-domain.com

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
TRANSPORT=stdio

# ── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECS=60
